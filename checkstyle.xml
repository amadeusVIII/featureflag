<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
        "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
        "https://checkstyle.org/dtds/configuration_1_3.dtd">
<module name="Checker">
    <property name="severity" value="error"/>

    <module name="TreeWalker">
        <!-- No unused imports cluttering the file -->
        <module name="UnusedImports"/>
        <!-- No wildcard imports (import com.example.*) — be explicit -->
        <module name="AvoidStarImport"/>
        <!-- Each file has at most one top-level class -->
        <module name="OneTopLevelClass"/>
        <!-- Braces always required, even for single-line if statements -->
        <module name="NeedBraces"/>
        <!-- Constant names must be UPPER_SNAKE_CASE -->
        <module name="ConstantName">
            <!-- Allow 'log' as a constant name — needed for @Slf4j compatibility -->
            <property name="format" value="^log$|^[A-Z][A-Z0-9]*(_[A-Z0-9]+)*$"/>
        </module>
        <!-- Method names must be camelCase -->
        <module name="MethodName"/>
    </module>

    <!-- No tab characters — use spaces -->
    <module name="FileTabCharacter"/>
    <!-- Every file must end with a newline -->
    <module name="NewlineAtEndOfFile"/>
</module>